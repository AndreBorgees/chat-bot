<!DOCTYPE HTML>
<html lang="pt-br">

<head>
	<meta charset="UTF-8">

	<title>Multiroom Chat</title>

	<!-- JQUERY -->
	<script src="js/jquery-2.2.1.js"></script>

	<!-- bootstrap - link cdn -->
	<link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.6/css/bootstrap.min.css"
		integrity="sha384-1q8mTJOASx8j1Au+a5WDVnPi2lkFfwwEAa8hDDdjZlpLegxhjVME1fgjWPGmkzs7" crossorigin="anonymous">

	<!-- estilo -->
	<link href="css/style.css" rel="stylesheet">

	<script type="text/javascript">

		$(document).ready(function () {
			$("#exibe_chat").click(function () {
				$("#conversa").show();
				$("#participantes").hide();
				ocultaNavbar();
			});

			$("#exibe_participantes").click(function () {
				$("#participantes").show();
				$("#conversa").hide();
				ocultaNavbar();
			});
		});

		function ocultaNavbar() {
			$("#btn_navbar_toggle").attr("class", "navbar-toggle collapsed");
			$("#navbar-collapse-1").attr("class", "navbar-collapse collapse");
			$("#btn_navbar_toggle").attr("aria-expanded", "false");
			$("#navbar-collapse-1").attr("aria-expanded", "false");
		}
	</script>
</head>

<body>


	<nav class="navbar navbar-default navbar-fixed-top" role="navigation">
		<div class="container">
			<div class="navbar-header">
				<button type="button" class="navbar-toggle" data-toggle="collapse" data-target="#navbar-collapse-1"
					id="btn_navbar_toggle">
					<span class="sr-only">Toggle navigation</span>
					<span class="icon-bar"></span>
					<span class="icon-bar"></span>
					<span class="icon-bar"></span>
				</button>
				<a class="navbar-brand" href="#">Multiroom Chat</a>
			</div>


			<div class="collapse navbar-collapse" id="navbar-collapse-1">
				<ul class="nav navbar-nav">
					<li>
						<a href="#" id="exibe_chat">Chat</a>
					</li>
					<li>
						<a href="#" id="exibe_participantes">Participantes</a>
					</li>
				</ul>
			</div>
		</div>
	</nav>

	<div class="container">
		<div class="row conversa" id="conversa">
			<div class="col-md-1"></div>
			<div class="col-md-10" id="dialogos">
			</div>
			<div class="col-md-1"></div>

		</div>

		<div class="row participantes" id="participantes" style="display:none">
			<div class="col-md-1"></div>
			<div class="col-md-10" id="pessoas">

			</div>
			<div class="col-md-1"></div>

		</div>
	</div>

	<nav class="navbar navbar-default navbar-fixed-bottom" role="navigation">
		<div class="container">
			<div class="panel-body campo-mensagem">

				<div class="col-md-12">
					<div class="input-group">
						<input type="text" class="form-control" placeholder="Mensagem" id="mensagem">
						<input type="hidden" value="<%=dadosForm.apelido%>" id="apelido">
						<input type="hidden" value="0" id="apelido_atualizado_nos_clientes">
						<span class="input-group-btn">
							<button class="btn btn-default" type="button" id="enviar_mensagem">></button>
						</span>
					</div>
				</div>

			</div>
		</div>
	</nav>

	<script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.6/js/bootstrap.min.js"
		integrity="sha384-0mSbJDEHialfmuBBQP6A4Qrprq5OVfW37PRR3j5ELqxss1yVqOtnepnHVP9aJ7xS"
		crossorigin="anonymous"></script>

	<!-- Recuperando o script do socket.io para poder utilizar Websocket no lado do cliente(browser do cliente). Para escutar e emitir mensagem, recuperar enventos 
		disparados pelo lado servidor e enviar enventos pro servidor-->
	<script src="/socket.io/socket.io.js"></script>
	<script>
		/*criando variavel que contém a instancia do objeto IO que está no arquivo JS a cima. Essa instancia espera um endereço no servidor onde ela vai econtrar 
		 uma conexão  Webscoket pra se comunicar(feita lá na app.js)*/
		var socket = io('http://localhost:80');

		/* Ouvindo os pedidos de execução vindos do servidor(emit) e pegando as informações vindas dessa função pela variavel data
		(que é o segundo parametro da função emit do lado servidor) do nosso callback */

		socket.on('msgParaCliente', function (data) {
			//Criando uma caixa de dialogo com o parametro da nossa função de callback e preenchendo a nossa div de dialogos la em cima.
			var html = '';

			html += '<div class="dialogo">';
			html += '<h4>' + data.apelido + '</h4>';
			html += '<p>' + data.mensagem + '</p>';
			html += '</div>';

			//incluindo nosso html criada na div la de cima(com o id dialogos) utilizando o jquery
			$('#dialogos').append(html);

			//Levando o scrool sempre para ultima mensagem enviada
			window.scrollTo(0, document.body.scrollHeight);
		});

		//Criando os participantes com o parametro da nossa função de callback e preenchendo o nossa span de pessoas la em cima.
		socket.on('participantesParaCliente', function (data) {
			var html = '';
			html += '<span class="participante">';
			html += '<img src="images/ico_usuario.png">';
			html += data.apelido;
			html += '</span>';

			//incluindo nosso html criada no span la de cima(com o id pessoas) utilizando o jquery
			$('#pessoas').append(html);
		})

		//jquery para capturar o evento do click do botão enviar_mensagem quando ele for clicado, e enviara uma mensagem para o servidor 
		$('#enviar_mensagem').click(function () {
			socket.emit(
				'msgParaServidor',
				{
					apelido: $('#apelido').val(),
					mensagem: $('#mensagem').val(),
					//Variavel iniciada com zero para não ficar cadastrando participantes repetidos
					apelido_atualizado_nos_clientes: $('#apelido_atualizado_nos_clientes').val()
				}
			);

			$('#mensagem').val("");
			$('#apelido_atualizado_nos_clientes').val(1)
		});

	</script>

</body>

</html>